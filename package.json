{
	"name": "obsidian-vault-activity",
	"version": "1.0.0",
	"description": "Obsidian plugin to track your note activity stats with streak highlights and visual trend windows",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"format": "prettier --write ."
	},
	"keywords": [
		"obsidian",
		"activity",
		"stats"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.19.15",
		"@vitest/coverage-v8": "^4.1.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"prettier": "^3.8.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
